---
import Header from "@/components/common/Header.astro";
import Footer from "@/components/common/Footer.astro";
import "@/assets/styles/style.scss";

const { title = "株式会社ミエフソー" } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<link rel="icon" href="/assets/favicon.svg" type="image/svg+xml" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100;300;400;500;700;900&family=Noto+Sans:wght@100;300;400;500;700;900&family=Noto+Serif+JP:wght@100;300;400;500;700;900&display=swap" rel="stylesheet">
</head>

<body>

<Header />

<main>
  <slot />
</main>

<Footer />


<script>
  import '@/assets/scripts/main';
</script>

</body>
</html>
