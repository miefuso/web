---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import TopBtn from "@/components/common/TopBtn.astro";
import { Image } from 'astro:assets';
import img01 from '@/assets/images/projects/pro_08_01.jpg';
import img02 from '@/assets/images/projects/pro_08_02.jpg';
import img03 from '@/assets/images/projects/pro_08_03.jpg';
import img04 from '@/assets/images/projects/pro_08_04.jpg';
import img05 from '@/assets/images/projects/pro_08_05.jpg';
import img06 from '@/assets/images/projects/pro_08_06.jpg';
import img07 from '@/assets/images/projects/pro_08_07.jpg';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="RF55ノーマンリングバーカー（エノ） | 導入実績 | 株式会社ミエフソー">
  <PageHeader
    title="製造実績"
    subtitle="Manufacturing Track Record"
    bgImage={img01}
  />

  <section class="p-case-study container">

    <div class="p-case-study__overview">
      <h2>RF55ノーマンリングバーカー（エノ）</h2>
      <p class="text-center-self">
        再生整備を施したRF55ノーマンリングバーカー（エノ）です。完全オーバーホールを実施し、各部品の状態を確認・修復することで新製品と同様の品質での納品を実現しました。現場条件に合わせた調整を行い、安定した稼働をご提供しております。
      </p>
    </div>

    <ul class="p-case-study__gallery-list">
      <li><Image src={img01} alt="RF55ノーマンリングバーカー（エノ） 1" /></li>
      <li><Image src={img02} alt="RF55ノーマンリングバーカー（エノ） 2" /></li>
      <li><Image src={img03} alt="RF55ノーマンリングバーカー（エノ） 3" /></li>
      <li><Image src={img04} alt="RF55ノーマンリングバーカー（エノ） 4" /></li>
      <li><Image src={img05} alt="RF55ノーマンリングバーカー（エノ） 5" /></li>
      <li><Image src={img06} alt="RF55ノーマンリングバーカー（エノ） 6" /></li>
      <li><Image src={img07} alt="RF55ノーマンリングバーカー（エノ） 7" /></li>
    </ul>

    <div class="p-case-study__back">
      <a href={`${base}/projects#mtr`} class="c-btn c-btn--g">導入実績一覧へ戻る</a>
    </div>

  </section>

  <TopBtn href="#" />

</BaseLayout>
